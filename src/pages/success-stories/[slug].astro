---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const stories = await getCollection('stories');
  return stories.map((s) => ({
    params: { slug: s.data.slug },
    props: { entry: s },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

const site = Astro.site!;
const toAbs = (p: string) => new URL(p, site).toString();

// Find next story in the chronologically-descending list (older next).
const all = (await getCollection('stories')).sort(
  (a, b) => new Date(b.data.publishedAt).valueOf() - new Date(a.data.publishedAt).valueOf()
);
const idx = all.findIndex((s) => s.data.slug === entry.data.slug);
const nextStory = all[(idx + 1) % all.length];
---

<ArticleLayout
  eyebrow={entry.data.condition ? `Patient Story · ${entry.data.condition}` : 'Patient Story'}
  title={entry.data.title}
  excerpt={entry.data.excerpt}
  publishedAt={entry.data.publishedAt}
  breadcrumbs={[
    { name: 'Home', url: toAbs('/') },
    { name: 'Success Stories', url: toAbs('/success-stories') },
    { name: entry.data.title, url: toAbs(`/success-stories/${entry.data.slug}`) },
  ]}
  relatedHeading="Where next"
>
  <Content />

  <Fragment slot="related">
    {nextStory && (
      <a href={`/success-stories/${nextStory.data.slug}`} class="card card-hover group block h-full flex flex-col">
        <p class="mono-caps text-ink-muted">Next patient story</p>
        {nextStory.data.condition && <p class="mono-caps text-ink-muted mt-1">{nextStory.data.condition}</p>}
        <h3 class="mt-3 font-display text-[19px] text-ink leading-tight group-hover:text-accent">{nextStory.data.title}</h3>
        <p class="mt-3 text-[15px] text-ink-soft leading-relaxed flex-1">{nextStory.data.excerpt}</p>
        <div class="mt-5 pt-4 border-t border-paper-3 flex items-center justify-between mono-caps text-ink-muted">
          <span>Read next story</span>
          <span class="text-ink group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>
    )}

    {entry.data.relatedService && entry.data.relatedServiceLabel && (
      <a href={entry.data.relatedService} class="card card-hover group block h-full flex flex-col">
        <p class="mono-caps text-ink-muted">The procedure</p>
        <h3 class="mt-3 font-display text-[19px] text-ink leading-tight group-hover:text-accent">
          Learn about <em class="italic text-accent">{entry.data.relatedServiceLabel}</em>
        </h3>
        <p class="mt-3 text-[15px] text-ink-soft leading-relaxed flex-1">
          What the procedure involves, recovery timeline, and when it is the right answer.
        </p>
        <div class="mt-5 pt-4 border-t border-paper-3 flex items-center justify-between mono-caps text-ink-muted">
          <span>Procedure details</span>
          <span class="text-ink group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>
    )}
  </Fragment>
</ArticleLayout>
