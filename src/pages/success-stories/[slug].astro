---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const stories = await getCollection('stories');
  return stories.map((s) => ({
    params: { slug: s.data.slug },
    props: { entry: s },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

const site = Astro.site!;
const toAbs = (p: string) => new URL(p, site).toString();

const related = (await getCollection('stories'))
  .filter((s) => s.data.slug !== entry.data.slug)
  .sort((a, b) => new Date(b.data.publishedAt).valueOf() - new Date(a.data.publishedAt).valueOf())
  .slice(0, 3);
---

<ArticleLayout
  eyebrow={entry.data.condition ? `Patient Story · ${entry.data.condition}` : 'Patient Story'}
  title={entry.data.title}
  excerpt={entry.data.excerpt}
  publishedAt={entry.data.publishedAt}
  breadcrumbs={[
    { name: 'Home', url: toAbs('/') },
    { name: 'Success Stories', url: toAbs('/success-stories') },
    { name: entry.data.title, url: toAbs(`/success-stories/${entry.data.slug}`) },
  ]}
  serviceLink={entry.data.relatedService && entry.data.relatedServiceLabel
    ? { href: entry.data.relatedService, label: entry.data.relatedServiceLabel }
    : undefined}
  relatedHeading="Other patient stories"
>
  <Content />

  <Fragment slot="related">
    {related.map((r) => (
      <a href={`/success-stories/${r.data.slug}`} class="card card-hover group block h-full flex flex-col">
        {r.data.condition && <p class="mono-caps text-ink-muted">{r.data.condition}</p>}
        <h3 class="mt-3 font-display text-[19px] text-ink leading-tight">{r.data.title}</h3>
        <p class="mt-3 text-[15px] text-ink-soft leading-relaxed flex-1">{r.data.excerpt}</p>
        <div class="mt-5 pt-4 border-t border-paper-3 flex items-center justify-between mono-caps text-ink-muted">
          <span>{r.data.outcomeTime ?? 'Read story'}</span>
          <span class="text-ink group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>
    ))}
  </Fragment>
</ArticleLayout>
