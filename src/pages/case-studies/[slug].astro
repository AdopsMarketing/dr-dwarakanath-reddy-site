---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const cases = await getCollection('cases');
  return cases.map((c) => ({
    params: { slug: c.data.slug },
    props: { entry: c },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

const site = Astro.site!;
const toAbs = (p: string) => new URL(p, site).toString();

const related = (await getCollection('cases'))
  .filter((c) => c.data.slug !== entry.data.slug)
  .sort((a, b) => new Date(b.data.publishedAt).valueOf() - new Date(a.data.publishedAt).valueOf())
  .slice(0, 3);
---

<ArticleLayout
  eyebrow={`Case ${entry.data.caseNumber}${entry.data.conditionName ? ' · ' + entry.data.conditionName : ''}`}
  title={entry.data.title}
  excerpt={entry.data.excerpt}
  publishedAt={entry.data.publishedAt}
  breadcrumbs={[
    { name: 'Home', url: toAbs('/') },
    { name: 'Interesting Cases', url: toAbs('/case-studies') },
    { name: entry.data.title, url: toAbs(`/case-studies/${entry.data.slug}`) },
  ]}
  serviceLink={entry.data.relatedService && entry.data.relatedServiceLabel
    ? { href: entry.data.relatedService, label: entry.data.relatedServiceLabel }
    : undefined}
  relatedHeading="Other cases"
>
  <Content />

  <Fragment slot="related">
    {related.map((r) => (
      <a href={`/case-studies/${r.data.slug}`} class="card card-hover group block h-full flex flex-col">
        <p class="mono-caps text-ink-muted tabular-nums">Case {r.data.caseNumber}</p>
        {r.data.conditionName && <p class="mono-caps text-ink-muted">{r.data.conditionName}</p>}
        <h3 class="mt-3 font-display text-[19px] text-ink leading-tight">{r.data.title.replace(/^Case\s+\d+:\s*/, '')}</h3>
        <p class="mt-3 text-[15px] text-ink-soft leading-relaxed flex-1">{r.data.excerpt}</p>
        <div class="mt-5 pt-4 border-t border-paper-3 flex items-center justify-between mono-caps text-ink-muted">
          <span>Read case</span>
          <span class="text-ink group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>
    ))}
  </Fragment>
</ArticleLayout>
