---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const cases = await getCollection('cases');
  return cases.map((c) => ({
    params: { slug: c.data.slug },
    props: { entry: c },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

const site = Astro.site!;
const toAbs = (p: string) => new URL(p, site).toString();

const all = (await getCollection('cases')).sort(
  (a, b) => new Date(b.data.publishedAt).valueOf() - new Date(a.data.publishedAt).valueOf()
);
const idx = all.findIndex((c) => c.data.slug === entry.data.slug);
const nextCase = all[(idx + 1) % all.length];
---

<ArticleLayout
  eyebrow={`Case ${entry.data.caseNumber}${entry.data.conditionName ? ' · ' + entry.data.conditionName : ''}`}
  title={entry.data.title}
  excerpt={entry.data.excerpt}
  publishedAt={entry.data.publishedAt}
  breadcrumbs={[
    { name: 'Home', url: toAbs('/') },
    { name: 'Interesting Cases', url: toAbs('/case-studies') },
    { name: entry.data.title, url: toAbs(`/case-studies/${entry.data.slug}`) },
  ]}
  relatedHeading="Where next"
>
  <Content />

  <Fragment slot="related">
    {nextCase && (
      <a href={`/case-studies/${nextCase.data.slug}`} class="card card-hover group block h-full flex flex-col">
        <p class="mono-caps text-ink-muted tabular-nums">Next · Case {nextCase.data.caseNumber}</p>
        {nextCase.data.conditionName && <p class="mono-caps text-ink-muted mt-1">{nextCase.data.conditionName}</p>}
        <h3 class="mt-3 font-display text-[19px] text-ink leading-tight group-hover:text-accent">{nextCase.data.title.replace(/^Case\s+\d+:\s*/, '')}</h3>
        <p class="mt-3 text-[15px] text-ink-soft leading-relaxed flex-1">{nextCase.data.excerpt}</p>
        <div class="mt-5 pt-4 border-t border-paper-3 flex items-center justify-between mono-caps text-ink-muted">
          <span>Read next case</span>
          <span class="text-ink group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>
    )}

    {entry.data.relatedService && entry.data.relatedServiceLabel && (
      <a href={entry.data.relatedService} class="card card-hover group block h-full flex flex-col">
        <p class="mono-caps text-ink-muted">The procedure</p>
        <h3 class="mt-3 font-display text-[19px] text-ink leading-tight group-hover:text-accent">
          Learn about <em class="italic text-accent">{entry.data.relatedServiceLabel}</em>
        </h3>
        <p class="mt-3 text-[15px] text-ink-soft leading-relaxed flex-1">
          What the procedure involves, recovery timeline, and when it is the right answer.
        </p>
        <div class="mt-5 pt-4 border-t border-paper-3 flex items-center justify-between mono-caps text-ink-muted">
          <span>Procedure details</span>
          <span class="text-ink group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>
    )}
  </Fragment>
</ArticleLayout>
