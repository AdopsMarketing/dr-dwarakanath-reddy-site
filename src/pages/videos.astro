---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import ExploreLink from '@/components/ExploreLink.astro';
import WhatsAppContextCTA from '@/components/WhatsAppContextCTA.astro';
import { getCollection } from 'astro:content';

const videos = (await getCollection('videos')).sort(
  (a, b) => a.data.order - b.data.order
);

const liveCount = videos.filter((v) => v.data.status === 'live').length;
const inProductionCount = videos.filter((v) => v.data.status === 'in-production').length;
const plannedCount = videos.filter((v) => v.data.status === 'planned').length;

const categoryLabels: Record<string, string> = {
  'patient-education': 'Patient education',
  'procedure-explainer': 'Procedure explainer',
  'recovery-guide': 'Recovery guide',
  'second-opinion': 'Second opinions',
  'practice': 'About the practice',
};

const statusLabels: Record<string, { label: string; cls: string }> = {
  'live': { label: 'Live', cls: 'bg-emerald-50 text-emerald-700 ring-emerald-200' },
  'in-production': { label: 'Filming', cls: 'bg-amber-50 text-amber-800 ring-amber-200' },
  'planned': { label: 'Planned', cls: 'bg-paper-2 text-ink-soft ring-paper-3' },
};
---

<BaseLayout
  pageType="generic"
  title="Patient education videos · Dr. Dwarakanath Reddy"
  description="Short, plain-language video explainers from Dr. Dwarakanath Reddy on common GI conditions, surgical decisions, recovery, and second opinions. Apollo Speciality Hospitals, Nellore."
  breadcrumbs={[
    { name: 'Home', url: new URL('/', Astro.site!).toString() },
    { name: 'Videos', url: new URL('/videos', Astro.site!).toString() },
  ]}
>
  <!-- HERO -->
  <section class="bg-paper-1">
    <div class="site-container py-14 lg:py-24">
      <nav class="fig-label mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-ink">Home</a>
        <span class="mx-2">·</span>
        <span class="text-ink">Videos</span>
      </nav>

      <div class="grid lg:grid-cols-12 gap-12 items-end">
        <div class="lg:col-span-8">
          <Eyebrow>Patient education videos</Eyebrow>
          <h1 class="mt-6 font-display text-[44px] md:text-[60px] lg:text-[76px] leading-[1] tracking-tight text-ink max-w-[16ch]">
            Short videos. <em>Plain</em> answers.
          </h1>
          <p class="mt-8 text-lg text-ink-soft leading-relaxed max-w-[60ch]">
            A growing library of short explainers from Dr. Reddy on the questions most patients arrive with: when surgery is needed, how decisions are made, what recovery looks like, and how second opinions work. New videos are added as they are produced.
          </p>
        </div>

        <aside class="lg:col-span-4 lg:pl-6 lg:border-l lg:border-paper-3">
          <p class="mono-caps text-ink-muted">Library status</p>
          <ul class="mt-4 space-y-2.5 text-ink">
            <li class="flex items-baseline justify-between gap-3">
              <span>Live</span>
              <span class="mono-caps text-ink-muted tabular-nums">{String(liveCount).padStart(2, '0')}</span>
            </li>
            <li class="flex items-baseline justify-between gap-3">
              <span>In production</span>
              <span class="mono-caps text-ink-muted tabular-nums">{String(inProductionCount).padStart(2, '0')}</span>
            </li>
            <li class="flex items-baseline justify-between gap-3">
              <span>Planned</span>
              <span class="mono-caps text-ink-muted tabular-nums">{String(plannedCount).padStart(2, '0')}</span>
            </li>
          </ul>
          <p class="mt-6 text-sm text-ink-soft leading-relaxed">
            While the video library is being recorded, the same questions are answered in writing on the FAQ page.
          </p>
          <div class="mt-4">
            <ExploreLink href="/faqs">View patient FAQs</ExploreLink>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- VIDEO GRID -->
  <section class="bg-paper-2 border-y border-paper-3">
    <div class="site-container py-16 lg:py-24">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {videos.map((v, i) => {
          const status = statusLabels[v.data.status];
          const isLive = v.data.status === 'live' && v.data.youtubeId;
          return (
            <article class="group flex flex-col bg-paper-1 border border-paper-3 rounded-sm overflow-hidden">
              <div class="aspect-video relative bg-ink/5 border-b border-paper-3">
                {isLive ? (
                  <a
                    href={`https://youtu.be/${v.data.youtubeId}`}
                    rel="noopener"
                    target="_blank"
                    class="absolute inset-0 flex items-center justify-center"
                    aria-label={`Watch: ${v.data.title}`}
                  >
                    <img
                      src={v.data.thumbnail ?? `https://img.youtube.com/vi/${v.data.youtubeId}/hqdefault.jpg`}
                      alt=""
                      loading="lazy"
                      class="absolute inset-0 w-full h-full object-cover"
                    />
                    <span class="relative z-10 w-14 h-14 rounded-full bg-paper-1/95 text-ink flex items-center justify-center font-display text-2xl group-hover:bg-accent group-hover:text-paper-1 transition-colors">
                      ▶
                    </span>
                  </a>
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-ink-muted">
                    <span class="font-display italic text-3xl opacity-30">{String(i + 1).padStart(2, '0')}</span>
                  </div>
                )}
              </div>
              <div class="p-5 flex-1 flex flex-col">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class={`mono-caps text-[10px] tracking-[0.12em] px-2 py-0.5 rounded-sm ring-1 ${status.cls}`}>
                    {status.label}
                  </span>
                  <span class="mono-caps text-ink-muted">{categoryLabels[v.data.category]}</span>
                  {v.data.duration && (
                    <span class="mono-caps text-ink-muted tabular-nums ml-auto">{v.data.duration}</span>
                  )}
                </div>
                <h2 class="mt-3 font-display text-xl text-ink leading-snug">
                  {v.data.title}
                </h2>
                <p class="mt-3 text-sm text-ink-soft leading-relaxed flex-1">
                  {v.data.description}
                </p>
                {v.data.relatedService && v.data.relatedServiceLabel && (
                  <div class="mt-5 pt-4 border-t border-paper-3">
                    <a href={v.data.relatedService} class="text-sm text-accent hover:underline">
                      Read about {v.data.relatedServiceLabel} →
                    </a>
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- BRIDGES -->
  <section class="bg-paper-1">
    <div class="site-container py-16 lg:py-20 grid lg:grid-cols-3 gap-10">
      <div>
        <Eyebrow>FAQs</Eyebrow>
        <h3 class="mt-4 font-display text-2xl text-ink leading-snug">Same questions, in writing</h3>
        <p class="mt-3 text-ink-soft leading-relaxed">
          The same topics covered on video are answered in 43 plain-text questions across appointments, costs, surgery, and recovery.
        </p>
        <div class="mt-5">
          <ExploreLink href="/faqs">Read patient FAQs</ExploreLink>
        </div>
      </div>
      <div>
        <Eyebrow>Procedure pages</Eyebrow>
        <h3 class="mt-4 font-display text-2xl text-ink leading-snug">A specific operation in mind?</h3>
        <p class="mt-3 text-ink-soft leading-relaxed">
          Each surgery has a dedicated page covering technique, eligibility, and recovery.
        </p>
        <div class="mt-5">
          <ExploreLink href="/gi-services">View GI services</ExploreLink>
        </div>
      </div>
      <div>
        <Eyebrow>Send a question</Eyebrow>
        <h3 class="mt-4 font-display text-2xl text-ink leading-snug">Want a video on something else?</h3>
        <p class="mt-3 text-ink-soft leading-relaxed">
          Suggestions from patients shape what gets recorded next. Send your topic on WhatsApp.
        </p>
        <div class="mt-5">
          <ExploreLink href="/contact">Open contact form</ExploreLink>
        </div>
      </div>
    </div>
  </section>

  <WhatsAppContextCTA
    eyebrow="Have a question?"
    prompt="Want a video <em>topic</em> covered next?"
    label="Suggest a topic on WhatsApp"
    message="Hi Dr. Reddy, I'd like a video covering this topic:"
  />
</BaseLayout>
