---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import ExploreLink from '@/components/ExploreLink.astro';
import WhatsAppContextCTA from '@/components/WhatsAppContextCTA.astro';
import { getCollection } from 'astro:content';

const allConditions = (await getCollection('conditions')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

// Group by relevantSpecialty so the page mirrors the GI Services topical structure.
const groupOrder = [
  'Surgical Gastroenterology',
  'Hepato-Pancreatico-Biliary Surgery',
  'Surgical Oncology (GI)',
  'Bariatric Surgery',
];

const groupMeta: Record<string, { eyebrow: string; heading: string; intro: string }> = {
  'Surgical Gastroenterology': {
    eyebrow: 'Common GI conditions',
    heading: 'General GI surgery',
    intro: 'The bread-and-butter of a GI surgical practice — gallstones, hernia, reflux, swallowing problems, and abdominal emergencies. Many of these are managed with day-care laparoscopic surgery.',
  },
  'Hepato-Pancreatico-Biliary Surgery': {
    eyebrow: 'Liver · pancreas · bile duct',
    heading: 'HPB conditions',
    intro: 'Diseases of the liver, pancreas, and biliary system. Often complex, often referred from other centres for a sub-specialty opinion.',
  },
  'Surgical Oncology (GI)': {
    eyebrow: 'GI cancers',
    heading: 'GI cancer',
    intro: 'Cancers of the digestive tract — coordinated curative-intent treatment with the broader Apollo oncology team for staging, neoadjuvant therapy, and follow-up.',
  },
  'Bariatric Surgery': {
    eyebrow: 'Metabolic and weight',
    heading: 'Metabolic disease',
    intro: 'Severe obesity with associated comorbidities, where medical and lifestyle therapy alone has been insufficient and bariatric surgery is being considered.',
  },
};

const grouped = groupOrder
  .map((specialty) => ({
    specialty,
    meta: groupMeta[specialty],
    conditions: allConditions.filter((c) => c.data.relevantSpecialty === specialty),
  }))
  .filter((g) => g.conditions.length > 0);

const whenToConsult = [
  { num: '01', title: 'A confirmed surgical condition', body: 'You\'ve been told you need surgery and want a sub-specialist opinion before proceeding.' },
  { num: '02', title: 'Persistent or worsening symptoms', body: 'Recurrent abdominal pain, unexplained weight loss, jaundice, blood in stool, or difficulty swallowing.' },
  { num: '03', title: 'A complex or recurrent problem', body: 'Recurrent hernia, complications of previous surgery, suspected cancer, or a difficult HPB case.' },
  { num: '04', title: 'A second opinion', body: 'You\'ve been advised that surgery is — or isn\'t — possible, and want a fresh review of your scans and reports.' },
];
---

<BaseLayout
  pageType="generic"
  title="Conditions we treat · Dr. Dwarakanath Reddy, Apollo Nellore"
  description="Surgical and medical conditions Dr. Dwarakanath Reddy treats at Apollo Speciality Hospitals, Nellore — gallstones, hernia, GERD, GI cancers, HPB, and bariatric. Not every condition needs surgery."
  breadcrumbs={[
    { name: 'Home', url: new URL('/', Astro.site!).toString() },
    { name: 'Conditions', url: new URL('/conditions', Astro.site!).toString() },
  ]}
>
  <!-- HERO -->
  <section class="bg-paper-1">
    <div class="site-container py-14 lg:py-24">
      <nav class="fig-label mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-ink">Home</a>
        <span class="mx-2">·</span>
        <span class="text-ink">Conditions</span>
      </nav>

      <Eyebrow>What we treat</Eyebrow>
      <h1 class="mt-6 font-display text-[40px] md:text-[60px] lg:text-[76px] leading-[1.02] tracking-tight text-ink max-w-[20ch]">
        Conditions we <em>treat</em>.
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-ink-soft max-w-[58ch]">
        A focused list of GI, HPB, oncology, and metabolic conditions for which Dr. Reddy provides surgical evaluation at Apollo Speciality Hospitals, Nellore.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-ink max-w-[58ch]">
        <strong>Not every condition needs surgery.</strong> Many patients leave a consultation with a non-surgical plan, a clearer diagnosis, or a referral elsewhere.
      </p>
    </div>
  </section>

  {grouped.map((g, gi) => (
    <section class={gi % 2 === 0 ? 'bg-paper-2 border-y border-paper-3' : 'bg-paper-1'}>
      <div class="site-container py-16 lg:py-20">
        <Eyebrow>{g.meta.eyebrow}</Eyebrow>
        <h2 class="mt-5 font-display text-[28px] lg:text-[40px] text-ink max-w-[22ch]">
          {g.meta.heading}
        </h2>
        <div class="mt-6 w-10 h-px bg-accent"></div>
        <p class="mt-6 text-base lg:text-lg text-ink-soft leading-relaxed max-w-[68ch]">
          {g.meta.intro}
        </p>

        <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {g.conditions.map((c) => (
            <a href={`/conditions/${c.data.slug}`} class="card card-hover group block h-full flex flex-col">
              {c.data.icd10Code && (
                <p class="mono-caps text-ink-muted tabular-nums">ICD-10 · {c.data.icd10Code}</p>
              )}
              <h3 class="mt-3 font-display text-[22px] text-ink leading-tight">
                {c.data.title}
              </h3>
              {c.data.alternateName.length > 0 && (
                <p class="mt-1 fig-label">
                  Also: {c.data.alternateName.slice(0, 2).join(' · ')}
                </p>
              )}
              <p class="mt-3 text-[15px] text-ink-soft leading-relaxed flex-1">
                {c.data.shortDescription}
              </p>
              <div class="mt-6 pt-4 border-t border-paper-3 flex items-center justify-between mono-caps text-ink-muted">
                <span>Read more</span>
                <span class="text-ink group-hover:translate-x-1 transition-transform">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="bg-paper-1">
    <div class="site-container py-16 lg:py-24">
      <Eyebrow>When to consult</Eyebrow>
      <h2 class="mt-5 font-display text-[32px] lg:text-[44px] text-ink max-w-[22ch]">
        When to see a <em>GI surgeon</em>.
      </h2>
      <div class="mt-6 w-10 h-px bg-accent"></div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {whenToConsult.map((w) => (
          <article>
            <p class="fig-label">Reason {w.num}</p>
            <h3 class="mt-3 font-display text-xl text-ink leading-snug">{w.title}</h3>
            <p class="mt-3 text-sm text-ink-soft leading-relaxed">{w.body}</p>
          </article>
        ))}
      </div>

      <div class="mt-12">
        <ExploreLink href="/gi-services">View procedures Dr. Reddy performs</ExploreLink>
      </div>
    </div>
  </section>

  <WhatsAppContextCTA
    eyebrow="Not sure where you fit?"
    prompt="Send your reports on WhatsApp for a <em>quick</em> initial review."
    label="Send reports on WhatsApp"
    message="Hi Dr. Reddy, I'd like to send my reports for an initial review."
  />
</BaseLayout>
