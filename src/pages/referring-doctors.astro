---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import ExploreLink from '@/components/ExploreLink.astro';
import WhatsAppContextCTA from '@/components/WhatsAppContextCTA.astro';
import { siteConfig, whatsappUrl } from '@/config/site';
import { getCollection } from 'astro:content';

const locations = await getCollection('locations');
const location = locations.find((l) => l.data.isPrimary) ?? locations[0];
const hospitalPhones = location
  ? Array.isArray(location.data.telephone)
    ? location.data.telephone
    : [location.data.telephone]
  : [];

const principles = [
  {
    num: '01',
    title: 'Super-specialist judgement',
    body: 'DNB Surgical Gastroenterology with HPB and oncology focus. Your patient is reviewed by a surgeon who operates only in this field — not a general surgeon adjacent to it.',
  },
  {
    num: '02',
    title: "Apollo's infrastructure",
    body: '24/7 surgical ICU, in-house CT and MRI, blood bank, and full multidisciplinary cover (critical care, cardiology, oncology). Patients with comorbidity are managed safely.',
  },
  {
    num: '03',
    title: 'Conservative when appropriate',
    body: 'Many referrals leave with a non-surgical plan. Most consultations begin by reviewing existing scans rather than ordering new ones. Your patient is not pushed toward surgery they do not need.',
  },
  {
    num: '04',
    title: 'You stay in the loop',
    body: 'Consultation note, operative note, discharge summary, histopathology, and structured follow-up are sent back to you. The referral is a partnership, not a handover.',
  },
];

const whenToRefer = [
  'Symptomatic gallstones, suspected acute cholecystitis, gallbladder polyps over 1 cm',
  'Inguinal, ventral, incisional, recurrent, and complex hernias — particularly cases needing eTEP',
  'Suspected GI malignancy on imaging or biopsy (oesophageal, gastric, colorectal, HPB)',
  'Pancreatic masses, complex pancreatic cysts, pancreatitis with surgical implications',
  'Liver lesions on imaging, suspected HCC, colorectal liver metastases',
  'Bariatric eligibility (BMI ≥ 32.5 with comorbidity, BMI ≥ 37.5 without)',
  'Diagnostic and therapeutic endoscopy or colonoscopy with biopsy',
  'Post-operative complications from surgery elsewhere — fistula, leak, recurrence, persistent pain',
];

const channels = [
  {
    num: '01',
    title: 'WhatsApp · doctor-to-doctor',
    detail:
      "Fastest route. Send patient summary, scans, and any biopsy reports. Dr. Reddy responds personally within a working day. Use the same number listed for patient bookings — identify yourself as a referring physician.",
    cta: { label: 'Open WhatsApp', message: 'Hi Dr. Reddy, I am a referring physician. I would like to discuss a patient.' },
  },
  {
    num: '02',
    title: 'Apollo Nellore · appointment desk',
    detail:
      "For patients you would like to book directly into the Apollo OPD, the hospital appointment desk runs 24/7. Mention this is a physician referral so the case is flagged for review of existing reports before the consult.",
    phone: hospitalPhones[0],
  },
  {
    num: '03',
    title: 'Written referral letter',
    detail:
      "A formal letter on your letterhead, scanned and emailed or sent with the patient, is welcomed for medico-legal continuity. Address to: Senior Consultant, Surgical Gastroenterology, Apollo Speciality Hospitals, Nellore.",
  },
];

const sendBack = [
  { label: 'Initial consultation note', detail: 'Within 24 hours of OPD review.' },
  { label: 'Pre-operative plan', detail: 'When surgery is offered, with rationale and alternatives.' },
  { label: 'Operative note', detail: 'On the day of surgery.' },
  { label: 'Discharge summary', detail: 'Signed by the consultant, with histopathology pending status if relevant.' },
  { label: 'Histopathology report', detail: 'Forwarded once available, typically 5 to 10 days post-op.' },
  { label: 'Structured follow-up updates', detail: 'For oncology cases — at every surveillance imaging point.' },
];

const waHref = whatsappUrl('Hi Dr. Reddy, I am a referring physician. I would like to discuss a patient.');
---

<BaseLayout
  pageType="generic"
  title="For referring physicians · Dr. Dwarakanath Reddy"
  description="For physicians referring patients in surgical gastroenterology, HPB, GI oncology, or bariatric surgery. Apollo Speciality Hospitals, Nellore."
  breadcrumbs={[
    { name: 'Home', url: new URL('/', Astro.site!).toString() },
    { name: 'Referring Doctors', url: new URL('/referring-doctors', Astro.site!).toString() },
  ]}
>
  <!-- HERO -->
  <section class="bg-paper-1">
    <div class="site-container py-14 lg:py-24">
      <nav class="fig-label mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-ink">Home</a>
        <span class="mx-2">·</span>
        <span class="text-ink">Referring Doctors</span>
      </nav>

      <div class="grid lg:grid-cols-12 gap-12 items-end">
        <div class="lg:col-span-8">
          <Eyebrow>For referring physicians</Eyebrow>
          <h1 class="mt-6 font-display text-[44px] md:text-[60px] lg:text-[72px] leading-[1.02] tracking-tight text-ink max-w-[18ch]">
            A surgical opinion, when one is <em>genuinely</em> useful.
          </h1>
          <p class="mt-8 text-lg text-ink-soft leading-relaxed max-w-[60ch]">
            Most referring physicians want the same things: a clear surgical opinion within days, not weeks; a patient who returns with a plan they understand; and timely written communication back to the practice. This page is for general physicians, gastroenterologists, medical oncologists, endocrinologists, and family doctors who refer to Dr. Reddy at Apollo Speciality Hospitals, Nellore.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href={waHref} class="btn btn-whatsapp">Discuss a referral on WhatsApp</a>
            <a href="#how-to-refer" class="btn btn-outline">See referral channels</a>
          </div>
        </div>

        <aside class="lg:col-span-4 lg:pl-6 lg:border-l lg:border-paper-3">
          <p class="mono-caps text-ink-muted">Direct line</p>
          <p class="mt-3 font-display text-xl text-ink">
            <a href={waHref} class="hover:text-accent">{siteConfig.doctor.phone}</a>
          </p>
          <p class="text-sm text-ink-soft">WhatsApp · doctor-to-doctor</p>

          <p class="mt-8 mono-caps text-ink-muted">Hospital desk</p>
          {hospitalPhones.map((num) => (
            <p class="mt-2 text-ink">
              <a href={`tel:${num.replace(/\s/g, '')}`} class="hover:text-accent">{num}</a>
            </p>
          ))}
          <p class="text-sm text-ink-soft mt-1">Apollo Nellore · 24/7</p>

          <p class="mt-8 mono-caps text-ink-muted">Email</p>
          <p class="mt-2 text-ink break-all">
            <a href="mailto:dwarak858@gmail.com" class="hover:text-accent">dwarak858@gmail.com</a>
          </p>
        </aside>
      </div>
    </div>
  </section>

  <!-- WHY REFER -->
  <section class="bg-paper-2 border-y border-paper-3">
    <div class="site-container py-16 lg:py-24">
      <Eyebrow>What you can expect</Eyebrow>
      <h2 class="mt-5 font-display text-[32px] lg:text-[44px] text-ink max-w-[20ch]">
        A partnership, not a <em>handover</em>.
      </h2>
      <div class="mt-6 w-10 h-px bg-accent"></div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {principles.map((p) => (
          <article>
            <p class="fig-label">Principle {p.num}</p>
            <h3 class="mt-3 font-display text-xl text-ink leading-snug">{p.title}</h3>
            <p class="mt-3 text-sm text-ink-soft leading-relaxed">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHEN TO REFER -->
  <section class="bg-paper-1">
    <div class="site-container py-16 lg:py-24 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4">
        <Eyebrow>Indications</Eyebrow>
        <h2 class="mt-5 font-display text-[28px] lg:text-[40px] text-ink max-w-[18ch]">
          When a surgical <em>opinion</em> adds value
        </h2>
        <div class="mt-6 w-10 h-px bg-accent"></div>
        <p class="mt-6 text-ink-soft leading-relaxed max-w-[42ch]">
          The list below is not exhaustive. If you are unsure whether a case warrants a surgical review, a brief WhatsApp message with a summary is the fastest way to find out — often the answer is no surgery is needed, and the patient is saved a trip.
        </p>
      </div>

      <ul class="lg:col-span-8 max-w-[68ch]">
        {whenToRefer.map((w) => (
          <li class="grid grid-cols-[auto_1fr] gap-4 py-4 border-t border-paper-3 first:border-t-0 first:pt-0 last:pb-0">
            <span class="mt-2 w-1.5 h-1.5 bg-accent shrink-0"></span>
            <span class="text-ink leading-relaxed">{w}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- HOW TO REFER -->
  <section id="how-to-refer" class="bg-paper-2 border-y border-paper-3 scroll-mt-24">
    <div class="site-container py-16 lg:py-24">
      <Eyebrow>Referral channels</Eyebrow>
      <h2 class="mt-5 font-display text-[32px] lg:text-[44px] text-ink max-w-[20ch]">
        Three ways to <em>refer</em>.
      </h2>
      <div class="mt-6 w-10 h-px bg-accent"></div>

      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {channels.map((c) => (
          <article class="rule-top pt-8">
            <p class="mono-caps text-ink-muted tabular-nums">{c.num}</p>
            <h3 class="mt-3 font-display text-2xl text-ink leading-snug">{c.title}</h3>
            <p class="mt-4 text-ink-soft leading-relaxed">{c.detail}</p>
            {c.cta && (
              <div class="mt-5">
                <a href={whatsappUrl(c.cta.message)} class="text-accent hover:underline">{c.cta.label} →</a>
              </div>
            )}
            {c.phone && (
              <div class="mt-5">
                <a href={`tel:${c.phone.replace(/\s/g, '')}`} class="text-accent hover:underline">{c.phone}</a>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- COMMUNICATION LOOP -->
  <section class="bg-paper-1">
    <div class="site-container py-16 lg:py-24 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <Eyebrow>The communication loop</Eyebrow>
        <h2 class="mt-5 font-display text-[28px] lg:text-[40px] text-ink max-w-[18ch]">
          What you receive in <em>return</em>
        </h2>
        <div class="mt-6 w-10 h-px bg-accent"></div>
        <p class="mt-6 text-ink-soft leading-relaxed max-w-[42ch]">
          Communication back to the referring physician is the single most under-served part of most surgical referrals. Dr. Reddy treats it as part of the case, not as paperwork.
        </p>
      </div>

      <ol class="lg:col-span-7 max-w-[64ch]">
        {sendBack.map((s, i) => (
          <li class="grid grid-cols-[auto_1fr] gap-4 items-baseline rule-top py-5 first:border-t-0 first:pt-0">
            <span class="mono-caps text-ink-muted tabular-nums">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <p class="font-display text-lg text-ink">{s.label}</p>
              <p class="mt-1 text-sm text-ink-soft">{s.detail}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- BRIDGES -->
  <section class="bg-paper-2 border-y border-paper-3">
    <div class="site-container py-16 lg:py-20 grid lg:grid-cols-3 gap-10">
      <div>
        <Eyebrow>About Dr. Reddy</Eyebrow>
        <h3 class="mt-4 font-display text-2xl text-ink leading-snug">Training and experience</h3>
        <p class="mt-3 text-ink-soft leading-relaxed">
          DNB Surgical Gastroenterology, Manipal Hospitals Bengaluru. 9+ years and 3,000+ surgeries. Full publication list and conference record on the About page.
        </p>
        <div class="mt-5">
          <ExploreLink href="/about-doctor">View profile</ExploreLink>
        </div>
      </div>
      <div>
        <Eyebrow>Procedures</Eyebrow>
        <h3 class="mt-4 font-display text-2xl text-ink leading-snug">Surgical scope</h3>
        <p class="mt-3 text-ink-soft leading-relaxed">
          Laparoscopic, HPB, GI oncology, and bariatric surgery — with detailed pages on technique and outcomes for each procedure.
        </p>
        <div class="mt-5">
          <ExploreLink href="/gi-services">View GI services</ExploreLink>
        </div>
      </div>
      <div>
        <Eyebrow>Hospital</Eyebrow>
        <h3 class="mt-4 font-display text-2xl text-ink leading-snug">Apollo Speciality Hospitals, Nellore</h3>
        <p class="mt-3 text-ink-soft leading-relaxed">
          24/7 surgical ICU, on-site imaging, blood bank, full multidisciplinary backup, and empanelment with all major insurers.
        </p>
        <div class="mt-5">
          <ExploreLink href="/contact">Hospital contacts</ExploreLink>
        </div>
      </div>
    </div>
  </section>

  <WhatsAppContextCTA
    eyebrow="Direct line"
    prompt="Have a case to <em>discuss</em> before referring?"
    label="Message Dr. Reddy on WhatsApp"
    message="Hi Dr. Reddy, I am a referring physician. I would like to discuss a patient before formally referring."
  />
</BaseLayout>
