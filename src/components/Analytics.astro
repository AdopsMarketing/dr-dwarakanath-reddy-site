---
/**
 * Analytics — Google Tag Manager + Microsoft Clarity, gated on cookie consent.
 *
 *  GTM (GTM-PNN6MZ5P) is the single source of truth for Google-side tags.
 *  GA4 (G-PLTQWN5SGW) is configured INSIDE GTM as a "GA4 Configuration" tag, not
 *  loaded directly here. To configure: GTM dashboard → Tags → New →
 *  Google Analytics: GA4 Configuration → Measurement ID: G-PLTQWN5SGW →
 *  Trigger: All Pages → Save → Submit → Publish.
 *
 *  Microsoft Clarity stays as a direct integration (cleaner for session replay).
 *
 *  Both load ONLY when window.__dprConsent.analytics === true. Listens for
 *  `dpr:consent-change` so users who change their mind via the footer Cookie
 *  preferences link are honoured immediately within the same page session.
 *
 *  Exposes globally:
 *    window.dataLayer       — always initialized so pages can queue events
 *    window.dprPushEvent()  — consent-respecting helper; use this from any
 *                             custom client-side code to fire GA4 events
 *                             (e.g. window.dprPushEvent({ event: 'whatsapp_click' }))
 *
 *  Auto-tracked clicks (delegated listener, fires only when analytics consent
 *  is granted): WhatsApp links (wa.me / whatsapp.com), tel: links, mailto: links.
 */

const GTM_ID = 'GTM-PNN6MZ5P';
const CLARITY_ID = 'wk7rfvfh4o';
---

<script is:inline define:vars={{ GTM_ID, CLARITY_ID }}>
(function () {
  // dataLayer initialized always (in-memory only — no transmission until GTM loads).
  window.dataLayer = window.dataLayer || [];

  // Public helper. Pushes only when analytics consent is granted.
  window.dprPushEvent = function (event) {
    if (window.__dprConsent && window.__dprConsent.analytics === true) {
      window.dataLayer.push(event);
    }
  };

  // Auto-track clicks on contact-affordance links. Delegated listener so it
  // captures every link on the page including those added later (defensive).
  document.addEventListener('click', function (e) {
    const link = e.target.closest && e.target.closest('a');
    if (!link) return;
    const href = link.getAttribute('href') || '';
    if (/^https?:\/\/wa\.me\//i.test(href) || /whatsapp\.com/i.test(href)) {
      window.dprPushEvent({
        event: 'whatsapp_click',
        link_source: link.getAttribute('data-track-source') || 'unspecified',
      });
    } else if (href.indexOf('tel:') === 0) {
      window.dprPushEvent({
        event: 'phone_click',
        phone_number: href.slice(4),
      });
    } else if (href.indexOf('mailto:') === 0) {
      window.dprPushEvent({ event: 'email_click' });
    }
  }, { passive: true });

  function loadGTM() {
    if (window.__dprGTMLoaded) return;
    window.__dprGTMLoaded = true;
    (function (w, d, s, l, i) {
      w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
      const f = d.getElementsByTagName(s)[0];
      const j = d.createElement(s);
      j.async = true;
      j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i;
      f.parentNode.insertBefore(j, f);
    })(window, document, 'script', 'dataLayer', GTM_ID);
  }

  function loadClarity() {
    if (window.__dprClarityLoaded) return;
    window.__dprClarityLoaded = true;
    (function (c, l, a, r, i, t, y) {
      c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
      t = l.createElement(r); t.async = 1; t.src = 'https://www.clarity.ms/tag/' + i;
      y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
    })(window, document, 'clarity', 'script', CLARITY_ID);
  }

  function apply(consent) {
    if (consent && consent.analytics === true) {
      loadGTM();
      loadClarity();
    }
  }

  // CookieBanner mounts before this component in BaseLayout, so __dprConsent
  // is already populated synchronously by the time we read it here.
  apply(window.__dprConsent);

  // Honour consent changes during the session.
  window.addEventListener('dpr:consent-change', function (event) {
    apply(event.detail);
  });
})();
</script>
