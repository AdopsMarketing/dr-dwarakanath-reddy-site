---
/**
 * Analytics — Google Analytics 4 + Microsoft Clarity, gated on cookie consent.
 *
 * Loads ONLY when `window.__dprConsent.analytics === true`. Reads consent
 * synchronously on page load (CookieBanner sets it before this component runs)
 * and listens for `dpr:consent-change` so users who change their mind via the
 * footer "Cookie preferences" link are honoured immediately.
 *
 * Idempotent: each script tag is added to <head> at most once per page load.
 *
 * Privacy-conscious defaults:
 *   - GA4: anonymize_ip: true
 *   - Clarity: respects do-not-track via its own server-side opt-outs
 *
 * If you remove either tool, just delete the corresponding ID below or strip
 * the loadX() function. Component is self-contained.
 */

const GA_ID = 'G-PLTQWN5SGW';
const CLARITY_ID = 'wk7rfvfh4o';
---

<script is:inline define:vars={{ GA_ID, CLARITY_ID }}>
(function () {
  function loadGA4() {
    if (window.__dprGA4Loaded) return;
    window.__dprGA4Loaded = true;
    const s = document.createElement('script');
    s.async = true;
    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
    document.head.appendChild(s);
    window.dataLayer = window.dataLayer || [];
    window.gtag = function () { window.dataLayer.push(arguments); };
    window.gtag('js', new Date());
    window.gtag('config', GA_ID, { anonymize_ip: true });
  }

  function loadClarity() {
    if (window.__dprClarityLoaded) return;
    window.__dprClarityLoaded = true;
    (function (c, l, a, r, i, t, y) {
      c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
      t = l.createElement(r); t.async = 1; t.src = 'https://www.clarity.ms/tag/' + i;
      y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
    })(window, document, 'clarity', 'script', CLARITY_ID);
  }

  function apply(consent) {
    if (consent && consent.analytics === true) {
      loadGA4();
      loadClarity();
    }
  }

  // CookieBanner mounts before this component in BaseLayout, so __dprConsent
  // is already populated synchronously by the time we read it here.
  apply(window.__dprConsent);

  // Pick up consent changes within the same session (e.g. user clicks Accept
  // after first declining, via the footer Cookie preferences link).
  window.addEventListener('dpr:consent-change', function (event) {
    apply(event.detail);
  });
})();
</script>
