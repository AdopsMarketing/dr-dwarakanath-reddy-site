---
interface Props {
  items: Array<{ name: string; url: string }>;
  class?: string;
}
const { items, class: className = 'text-sm text-ink-muted' } = Astro.props;
---

<nav aria-label="Breadcrumb" class={className}>
  <ol class="flex flex-wrap items-center gap-1">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i < items.length - 1 ? (
          <a href={item.url} class="hover:text-accent">
            <span>{item.name}</span>
          </a>
        ) : (
          <span class="text-ink-soft">{item.name}</span>
        )}
        {i < items.length - 1 && <span class="mx-1 text-ink-muted">/</span>}
      </li>
    ))}
  </ol>
</nav>
