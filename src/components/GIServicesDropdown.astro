---
import { giServicesMenu } from '@/data/megaMenu';
---

<div
  id="gi-services-panel"
  data-mega-panel
  role="region"
  aria-label="GI Services"
  class="hidden lg:block absolute left-0 right-0 top-full bg-paper-1 border-b border-paper-3 opacity-0 invisible -translate-y-1 pointer-events-none transition duration-200 ease-out data-[open]:opacity-100 data-[open]:visible data-[open]:translate-y-0 data-[open]:pointer-events-auto"
>
  <div class="site-container py-10 lg:py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-10">
      {giServicesMenu.map((item) => (
        <a href={item.href} class="group block">
          <p class="eyebrow">{item.eyebrow}</p>
          <span class="block mt-2 font-display text-[19px] text-ink leading-tight decoration-accent underline-offset-[6px] group-hover:underline group-hover:text-accent">
            {item.title}
          </span>
          <p class="mt-1.5 text-sm text-ink-muted leading-snug">{item.subline}</p>
        </a>
      ))}
    </div>

    <div class="mt-10 pt-4 border-t border-[color:var(--hairline)] flex items-center justify-between gap-4">
      <p class="mono-caps text-ink-muted">Seeing all procedures · 9 Services · Phase 1</p>
      <a href="/gi-services" class="group inline-flex items-center gap-1.5 mono-caps text-accent hover:text-accent-soft">
        View all procedures
        <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</div>
