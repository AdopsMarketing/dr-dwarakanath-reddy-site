---
import { getCollection } from 'astro:content';

const categories = (await getCollection('categories'))
  .filter((c) => c.data.slug !== 'surgical-gastroenterology') // shown first separately
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));

const featured = (await getCollection('categories')).find(
  (c) => c.data.slug === 'surgical-gastroenterology'
);

const allCategories = [...(featured ? [featured] : []), ...categories];
---

<div
  id="gi-services-panel"
  data-mega-panel
  role="region"
  aria-label="GI Services"
  class="hidden lg:block absolute left-0 right-0 top-full bg-paper-1 border-b border-paper-3 opacity-0 invisible -translate-y-1 pointer-events-none transition duration-200 ease-out data-[open]:opacity-100 data-[open]:visible data-[open]:translate-y-0 data-[open]:pointer-events-auto"
>
  <div class="site-container py-10 lg:py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-10">
      {allCategories.map((cat) => {
        const subline = (cat.data.h1Secondary ?? '').split(' · ')[0];
        return (
          <a href={`/gi-services/${cat.data.slug}`} class="group block">
            <p class="eyebrow">{cat.data.navEyebrow ?? ''}</p>
            <span class="block mt-2 font-display text-[19px] text-ink leading-tight decoration-accent underline-offset-[6px] group-hover:underline group-hover:text-accent">
              {cat.data.title}
            </span>
            <p class="mt-1.5 text-sm text-ink-muted leading-snug">{subline}</p>
          </a>
        );
      })}
    </div>

    <div class="mt-10 pt-4 border-t border-[color:var(--hairline)] flex flex-wrap items-center gap-x-8 gap-y-3">
      <p class="mono-caps text-ink-muted shrink-0">Diagnostic procedures</p>
      <a href="/gi-services/endoscopy" class="mono-caps text-ink-soft hover:text-accent">Endoscopy</a>
      <a href="/gi-services/colonoscopy" class="mono-caps text-ink-soft hover:text-accent">Colonoscopy</a>
      <a href="/gi-services/ercp" class="mono-caps text-ink-soft hover:text-accent">ERCP</a>
      <a href="/gi-services" class="group inline-flex items-center gap-1.5 mono-caps text-accent hover:text-accent-soft ml-auto">
        View all procedures
        <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</div>
