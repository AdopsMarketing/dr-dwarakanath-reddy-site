---
import type { CollectionEntry } from 'astro:content';
import Eyebrow from '@/components/Eyebrow.astro';
import ExploreLink from '@/components/ExploreLink.astro';
import WhatsAppContextCTA from '@/components/WhatsAppContextCTA.astro';

interface Props {
  category: CollectionEntry<'categories'>;
}

const { category } = Astro.props;
const d = category.data;
---

<section class="bg-paper-1">
  <div class="site-container py-14 lg:py-20">
    <nav class="fig-label mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink">Home</a>
      <span class="mx-2">·</span>
      <a href="/gi-services" class="hover:text-ink">GI Services</a>
      <span class="mx-2">·</span>
      <span class="text-ink">{d.h1 ?? d.title}</span>
    </nav>

    <Eyebrow>Category · Surgical gastroenterology</Eyebrow>

    {d.h1Html ? (
      <h1 class="mt-5 font-display text-[32px] md:text-[48px] lg:text-[60px] leading-[1.05] tracking-tight text-ink max-w-[22ch]" set:html={d.h1Html}></h1>
    ) : (
      <h1 class="mt-5 font-display text-[32px] md:text-[48px] lg:text-[60px] leading-[1.05] tracking-tight text-ink max-w-[22ch]">
        {d.h1 ?? d.title}
      </h1>
    )}

    {d.h1Secondary && (
      <p class="mt-4 font-display text-[18px] lg:text-[22px] text-ink-soft leading-snug max-w-[58ch]">
        {d.h1Secondary}
      </p>
    )}

    <p class="mt-6 text-lg leading-relaxed text-ink-soft max-w-[58ch]">{d.heroIntro}</p>
  </div>
</section>

{d.whatWeCover && (
  <section class="bg-paper-2 border-y border-paper-3">
    <div class="site-container py-16 lg:py-20">
      <Eyebrow>What we cover</Eyebrow>

      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {d.whatWeCover.items.map((item, i) => {
          const num = String(i + 1).padStart(2, '0');
          return item.href ? (
            <a href={item.href} class="card card-hover group h-full flex flex-col">
              <h3 class="font-display text-[20px] text-ink leading-tight">{item.title}</h3>
              {item.description && <p class="mt-3 text-[15px] text-ink-soft leading-relaxed flex-1">{item.description}</p>}
              <div class="mt-6 pt-4 border-t border-paper-3 flex items-center justify-between mono-caps text-ink-muted">
                <span>Learn more</span>
                <span class="text-ink group-hover:translate-x-1 transition-transform">→</span>
              </div>
            </a>
          ) : (
            <div class="card h-full flex flex-col border-dashed">
              <h3 class="font-display text-[20px] text-ink leading-tight">{item.title}</h3>
              {item.description && <p class="mt-3 text-[15px] text-ink-soft leading-relaxed flex-1">{item.description}</p>}
              <div class="mt-6 pt-4 border-t border-paper-3 mono-caps text-ink-muted">Phase 2</div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
)}

{d.sections.length > 0 && (
  <section class="bg-paper-1">
    <div class="site-container py-16 lg:py-20">
      <div class="max-w-[62ch] space-y-14">
        {d.sections.map((section, i) => {
          const num = String(i + 1).padStart(2, '0');
          return (
            <article>
              <p class="mono-caps text-ink-muted tabular-nums">{num}</p>
              <h2 class="mt-2 font-display text-[26px] lg:text-[32px] leading-[1.15] text-ink">{section.title}</h2>
              <div class="mt-4 w-10 h-px bg-accent"></div>

              {section.type === 'prose' && (
                <p class="mt-6 text-ink-soft leading-relaxed">{section.body}</p>
              )}
              {section.type === 'list' && (
                <div class="mt-6 space-y-5">
                  {section.intro && <p class="text-ink-soft leading-relaxed">{section.intro}</p>}
                  <ul class="space-y-2.5">
                    {section.items.map((item) => (
                      <li class="flex items-start gap-3 text-ink-soft">
                        <span class="mt-2 w-1.5 h-1.5 bg-accent shrink-0"></span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                  {section.outro && <p class="text-ink-soft leading-relaxed">{section.outro}</p>}
                </div>
              )}
              {section.type === 'steps' && (
                <div class="mt-6 space-y-5">
                  {section.intro && <p class="text-ink-soft leading-relaxed">{section.intro}</p>}
                  <ol class="space-y-4">
                    {section.steps.map((step, j) => (
                      <li class="flex items-baseline gap-4 text-ink-soft">
                        <span class="mono-caps text-ink-muted tabular-nums shrink-0">{String(j + 1).padStart(2, '0')}</span>
                        <span>{step}</span>
                      </li>
                    ))}
                  </ol>
                  {section.outro && <p class="text-ink-soft leading-relaxed">{section.outro}</p>}
                </div>
              )}
              {section.type === 'faqs' && (
                <div class="mt-6">
                  {section.items.map((faq) => (
                    <details class="faq">
                      <summary>{faq.question}</summary>
                      <div class="faq-body">{faq.answer}</div>
                    </details>
                  ))}
                </div>
              )}
            </article>
          );
        })}

        <div class="pt-8 rule-top">
          <ExploreLink href="/gi-services">See all procedures in this area</ExploreLink>
        </div>
      </div>
    </div>
  </section>
)}

{d.closingCta && (
  <WhatsAppContextCTA
    eyebrow="Next step"
    prompt={d.closingCta.prompt}
    label={d.closingCta.label}
    message={d.closingCta.message}
  />
)}
